    <SolidColorBrush x:Key="AppSidebarBrush" Color="#0A0B0F" />
    <SolidColorBrush x:Key="AppTopBarBrush" Color="#0F1218" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="#121722" />
    <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#1A202C" />
    <SolidColorBrush x:Key="AppSurfaceRaisedBrush" Color="#202838" />
    <SolidColorBrush x:Key="AppBorderBrush" Color="#2A3342" />
    <SolidColorBrush x:Key="AppBorderStrongBrush" Color="#394456" />
    <SolidColorBrush x:Key="AppTextBrush" Color="#F4F7FB" />
