    <SolidColorBrush x:Key="AppInputFocusBrush" Color="#232D3D" />
    <SolidColorBrush x:Key="AppOverlayBrush" Color="#090B10" />

    <CornerRadius x:Key="AppCardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="AppControlCornerRadius">6</CornerRadius>
    <Thickness x:Key="AppCardPadding">20</Thickness>
</ResourceDictionary>
