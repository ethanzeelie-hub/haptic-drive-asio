<Application x:Class="HapticDrive.Asio.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#0B0F14" />
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="#111820" />
        <SolidColorBrush x:Key="AppSurfaceAltBrush" Color="#17212B" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#263241" />
        <SolidColorBrush x:Key="AppTextBrush" Color="#E8EEF6" />
        <SolidColorBrush x:Key="AppMutedTextBrush" Color="#99A8B8" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#3BAFDA" />
        <SolidColorBrush x:Key="AppDangerBrush" Color="#E5534B" />
        <SolidColorBrush x:Key="AppSuccessBrush" Color="#39B980" />

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="16,6" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource AppMutedTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Application.Resources>
</Application>
