<UserControl x:Class="HapticDrive.Asio.App.Views.AdvancedDiagnosticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="1400"
             d:DesignWidth="980">
    <StackPanel x:Name="AdvancedDiagnosticsPage">
        <Border x:Name="AdvancedPhprDiagnosticsPanel"
                Style="{StaticResource CardBorderStyle}"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeadingTextBlockStyle}"
                           Text="Advanced Diagnostics" />
                <CheckBox x:Name="AdvancedDiagnosticsEnabledCheckBox"
                          Margin="0,14,0,0"
                          AutomationProperties.Name="Show advanced diagnostics and research controls"
                          Checked="AdvancedDiagnosticsEnabledCheckBox_Changed"
                          Unchecked="AdvancedDiagnosticsEnabledCheckBox_Changed"
                          Content="Show advanced diagnostics and research controls" />
                <TextBlock x:Name="AdvancedDiagnosticsGateText"
                           Margin="0,8,0,0"
                           Style="{StaticResource MutedTextBlockStyle}"
                           Text="Advanced diagnostics are hidden by default. Normal P-HPR mock controls, paddle mapping, and emergency stop are available on Devices without enabling this." />
                <StackPanel x:Name="AdvancedDiagnosticsContentPanel"
                            Visibility="Collapsed">
                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="P-HPR Workflow Summary" />
                    <TextBlock x:Name="PhprWorkflowStatusText"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap" />
                    <ItemsControl x:Name="PhprWorkflowItemsControl"
                                  Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="P-HPR Live F1 Validation" />
                    <TextBlock x:Name="PhprLiveF1ValidationStatusText"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap" />
                    <ItemsControl x:Name="PhprLiveF1ValidationItemsControl"
                                  Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="P-HPR Software Coexistence" />
                    <TextBlock x:Name="PhprCoexistenceStatusText"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap" />
                    <ItemsControl x:Name="PhprCoexistenceItemsControl"
                                  Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="P-HPR Direct Write Readiness" />
                    <TextBlock x:Name="PhprControlledWriteReadinessStatusText"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap" />
                    <ItemsControl x:Name="PhprControlledWriteReadinessItemsControl"
                                  Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="P-HPR Real Direct Control" />
                    <TextBlock Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Manual low-strength hardware output only. Startup may auto-select and validate a known P-HPR device, but no pulse is sent until a test button or mapped paddle is pressed."
                               TextWrapping="Wrap" />
                    <WrapPanel Margin="0,10,0,0">
                        <CheckBox x:Name="RealPhprDirectControlEnabledCheckBox"
                                  Margin="0,4,12,8"
                                  Checked="RealPhprDirectControlCheckBox_Changed"
                                  Unchecked="RealPhprDirectControlCheckBox_Changed"
                                  Content="Enable real direct control" />
                        <CheckBox x:Name="RealPhprDirectControlArmCheckBox"
                                  Margin="0,4,12,8"
                                  Checked="RealPhprDirectControlCheckBox_Changed"
                                  Unchecked="RealPhprDirectControlCheckBox_Changed"
                                  Content="Arm direct control" />
                        <Button Width="190"
                                Margin="0,0,8,8"
                                Click="RefreshRealPhprCandidatesButton_Click"
                                Content="Refresh Candidates" />
                        <Button Width="170"
                                Margin="0,0,8,8"
                                Click="DryRunRealPhprSelectionButton_Click"
                                Content="Dry Run Gates" />
                        <Button Width="150"
                                Margin="0,0,8,8"
                                Click="OpenCheckRealPhprSelectionButton_Click"
                                Content="Open Check" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Candidate" />
                        <ComboBox x:Name="RealPhprCandidateComboBox"
                                  Width="620"
                                  Margin="0,0,8,8"
                                  SelectionChanged="RealPhprCandidateComboBox_SelectionChanged" />
                        <Button Width="170"
                                Margin="0,0,8,8"
                                Click="ApplyRealPhprSelectionButton_Click"
                                Content="Apply Selection" />
                    </WrapPanel>
                    <TextBlock x:Name="RealPhprCandidatePickerStatusText"
                               Margin="0,2,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap" />
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Interface" />
                        <TextBox x:Name="RealPhprInterfaceTextBox"
                                 Width="180"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Report ID" />
                        <TextBox x:Name="RealPhprReportIdTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Report bytes" />
                        <TextBox x:Name="RealPhprReportLengthTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Transport" />
                        <ComboBox x:Name="RealPhprReportTransportComboBox"
                                  Width="130"
                                  Margin="0,0,8,8"
                                  SelectionChanged="RealPhprDirectControlCheckBox_Changed" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Approval phrase" />
                        <TextBox x:Name="RealPhprApprovalPhraseTextBox"
                                 Width="360"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0"
                               Visibility="Collapsed">
                        <TextBlock Width="86"
                                   Margin="0,4,8,8"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Brake" />
                        <CheckBox x:Name="RealPhprBrakeEnabledCheckBox"
                                  Margin="0,4,12,8"
                                  Checked="RealPhprDirectControlCheckBox_Changed"
                                  Unchecked="RealPhprDirectControlCheckBox_Changed"
                                  Content="Enabled" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Strength %" />
                        <TextBox x:Name="RealPhprBrakeStrengthTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Hz" />
                        <TextBox x:Name="RealPhprBrakeFrequencyTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Duration ms" />
                        <TextBox x:Name="RealPhprBrakeDurationTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0"
                               Visibility="Collapsed">
                        <TextBlock Width="86"
                                   Margin="0,4,8,8"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Throttle" />
                        <CheckBox x:Name="RealPhprThrottleEnabledCheckBox"
                                  Margin="0,4,12,8"
                                  Checked="RealPhprDirectControlCheckBox_Changed"
                                  Unchecked="RealPhprDirectControlCheckBox_Changed"
                                  Content="Enabled" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Strength %" />
                        <TextBox x:Name="RealPhprThrottleStrengthTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Hz" />
                        <TextBox x:Name="RealPhprThrottleFrequencyTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Duration ms" />
                        <TextBox x:Name="RealPhprThrottleDurationTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                    </WrapPanel>
                    <TextBlock Margin="0,12,0,0"
                               FontWeight="SemiBold"
                               Text="Real P-HPR Effect Low-Level Diagnostics" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Normal road/slip/lock enable and strength controls are on Effects. Advanced keeps minimums, frequency ranges, internal command durations, and target overrides." />
                    <WrapPanel Margin="0,8,0,0">
                        <TextBlock Width="86"
                                   Margin="0,4,8,8"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Road brake" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Minimum strength %" />
                        <TextBox x:Name="RealRoadBrakeMinStrengthTextBox"
                                 Width="60"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Min/Max Hz" />
                        <TextBox x:Name="RealRoadBrakeMinFrequencyTextBox"
                                 Width="60"
                                 Margin="0,0,4,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBox x:Name="RealRoadBrakeFrequencyTextBox"
                                 Width="60"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Duration ms" />
                        <TextBox x:Name="RealRoadBrakeDurationTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <TextBlock Width="86"
                                   Margin="0,4,8,8"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Road throttle" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Minimum strength %" />
                        <TextBox x:Name="RealRoadThrottleMinStrengthTextBox"
                                 Width="60"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Min/Max Hz" />
                        <TextBox x:Name="RealRoadThrottleMinFrequencyTextBox"
                                 Width="60"
                                 Margin="0,0,4,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBox x:Name="RealRoadThrottleFrequencyTextBox"
                                 Width="60"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Duration ms" />
                        <TextBox x:Name="RealRoadThrottleDurationTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <TextBlock Width="86"
                                   Margin="0,4,8,8"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Wheel slip" />
                        <ComboBox x:Name="RealSlipTargetComboBox"
                                  Width="126"
                                  Margin="0,0,8,8"
                                  SelectionChanged="RealPhprDirectControlCheckBox_Changed" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Minimum strength %" />
                        <TextBox x:Name="RealSlipMinStrengthTextBox"
                                 Width="60"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Min/Max Hz" />
                        <TextBox x:Name="RealSlipMinFrequencyTextBox"
                                 Width="60"
                                 Margin="0,0,4,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBox x:Name="RealSlipFrequencyTextBox"
                                 Width="60"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Duration ms" />
                        <TextBox x:Name="RealSlipDurationTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <TextBlock Width="86"
                                   Margin="0,4,8,8"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Wheel lock" />
                        <ComboBox x:Name="RealLockTargetComboBox"
                                  Width="126"
                                  Margin="0,0,8,8"
                                  SelectionChanged="RealPhprDirectControlCheckBox_Changed" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Minimum strength %" />
                        <TextBox x:Name="RealLockMinStrengthTextBox"
                                 Width="60"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Min/Max Hz" />
                        <TextBox x:Name="RealLockMinFrequencyTextBox"
                                 Width="60"
                                 Margin="0,0,4,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBox x:Name="RealLockFrequencyTextBox"
                                 Width="60"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Duration ms" />
                        <TextBox x:Name="RealLockDurationTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="RealPhprDirectControl_LostFocus" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <Button x:Name="TestRealPhprBrakePulseButton"
                                Width="190"
                                Margin="0,0,8,8"
                                Click="TestRealPhprBrakePulseButton_Click"
                                Content="Test Brake Pulse" />
                        <Button x:Name="TestRealPhprThrottlePulseButton"
                                Width="200"
                                Margin="0,0,8,8"
                                Click="TestRealPhprThrottlePulseButton_Click"
                                Content="Test Throttle Pulse" />
                        <Button Width="170"
                                Margin="0,0,8,8"
                                Click="RealPhprEmergencyStopButton_Click"
                                Content="Emergency Stop" />
                        <Button Width="200"
                                Margin="0,0,8,8"
                                Click="ClearRealPhprEmergencyStopButton_Click"
                                Content="Clear Emergency Stop" />
                    </WrapPanel>
                    <TextBlock x:Name="RealPhprDirectStatusText"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap" />
                    <ItemsControl x:Name="RealPhprDirectItemsControl"
                                  Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="Mock P-HPR Gear Routing" />
                    <WrapPanel Margin="0,10,0,0">
                        <CheckBox x:Name="MockGearPulseEnabledCheckBox"
                                  Margin="0,4,12,8"
                                  Checked="MockGearPulseControl_Changed"
                                  Unchecked="MockGearPulseControl_Changed"
                                  Content="Enable Mock Routing" />
                        <ComboBox x:Name="MockGearPulseTargetComboBox"
                                  Width="150"
                                  Margin="0,0,8,8"
                                  SelectionChanged="MockGearPulseControl_Changed" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Strength %" />
                        <TextBox x:Name="MockGearPulseStrengthTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockGearPulseControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Hz" />
                        <TextBox x:Name="MockGearPulseFrequencyTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockGearPulseControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Duration ms" />
                        <TextBox x:Name="MockGearPulseDurationTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockGearPulseControl_LostFocus" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <Button Width="210"
                                Margin="0,0,8,8"
                                Click="ClearMockGearPulseDiagnosticsButton_Click"
                                Content="Clear Mock Routing Diagnostics" />
                        <Button Width="170"
                                Margin="0,0,8,8"
                                Click="MockGearPulseEmergencyStopButton_Click"
                                Content="Mock Emergency Stop" />
                        <Button Width="210"
                                Margin="0,0,8,8"
                                Click="ClearMockGearPulseEmergencyStopButton_Click"
                                Content="Clear Mock Emergency Stop" />
                    </WrapPanel>
                    <TextBlock x:Name="MockGearPulseStatusText"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap" />
                    <ItemsControl x:Name="MockGearPulseItemsControl"
                                  Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBlock Margin="0,18,0,0"
                               FontWeight="SemiBold"
                               Text="Mock P-HPR Pedal Effects Routing" />
                    <WrapPanel Margin="0,10,0,0">
                        <CheckBox x:Name="MockPedalEffectsEnabledCheckBox"
                                  Margin="0,4,12,8"
                                  Checked="MockPedalEffectsControl_Changed"
                                  Unchecked="MockPedalEffectsControl_Changed"
                                  Content="Enable Pedal Effects" />
                        <Button Width="220"
                                Margin="0,0,8,8"
                                Click="ClearMockPedalEffectsDiagnosticsButton_Click"
                                Content="Clear Pedal Effects Diagnostics" />
                        <Button Width="190"
                                Margin="0,0,8,8"
                                Click="MockPedalEffectsEmergencyStopButton_Click"
                                Content="Pedal Effects Emergency Stop" />
                        <Button Width="230"
                                Margin="0,0,8,8"
                                Click="ClearMockPedalEffectsEmergencyStopButton_Click"
                                Content="Clear Pedal Effects Emergency Stop" />
                    </WrapPanel>
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Mock only, no hardware output." />
                    <WrapPanel Margin="0,12,0,0">
                        <TextBlock Width="96"
                                   Margin="0,4,8,8"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Road" />
                        <CheckBox x:Name="RoadPedalEffectEnabledCheckBox"
                                  Margin="0,4,12,8"
                                  Checked="MockPedalEffectsControl_Changed"
                                  Unchecked="MockPedalEffectsControl_Changed"
                                  Content="Enabled" />
                        <ComboBox x:Name="RoadPedalEffectTargetComboBox"
                                  Width="150"
                                  Margin="0,0,8,8"
                                  SelectionChanged="MockPedalEffectsControl_Changed" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Strength %" />
                        <TextBox x:Name="RoadPedalEffectStrengthTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockPedalEffectsControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Hz" />
                        <TextBox x:Name="RoadPedalEffectFrequencyTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockPedalEffectsControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Duration ms" />
                        <TextBox x:Name="RoadPedalEffectDurationTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockPedalEffectsControl_LostFocus" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <TextBlock Width="96"
                                   Margin="0,4,8,8"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Wheel Slip" />
                        <CheckBox x:Name="SlipPedalEffectEnabledCheckBox"
                                  Margin="0,4,12,8"
                                  Checked="MockPedalEffectsControl_Changed"
                                  Unchecked="MockPedalEffectsControl_Changed"
                                  Content="Enabled" />
                        <ComboBox x:Name="SlipPedalEffectTargetComboBox"
                                  Width="150"
                                  Margin="0,0,8,8"
                                  SelectionChanged="MockPedalEffectsControl_Changed" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Strength %" />
                        <TextBox x:Name="SlipPedalEffectStrengthTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockPedalEffectsControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Hz" />
                        <TextBox x:Name="SlipPedalEffectFrequencyTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockPedalEffectsControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Duration ms" />
                        <TextBox x:Name="SlipPedalEffectDurationTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockPedalEffectsControl_LostFocus" />
                    </WrapPanel>
                    <WrapPanel Margin="0,2,0,0">
                        <TextBlock Width="96"
                                   Margin="0,4,8,8"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="Wheel Lock" />
                        <CheckBox x:Name="LockPedalEffectEnabledCheckBox"
                                  Margin="0,4,12,8"
                                  Checked="MockPedalEffectsControl_Changed"
                                  Unchecked="MockPedalEffectsControl_Changed"
                                  Content="Enabled" />
                        <ComboBox x:Name="LockPedalEffectTargetComboBox"
                                  Width="150"
                                  Margin="0,0,8,8"
                                  SelectionChanged="MockPedalEffectsControl_Changed" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Strength %" />
                        <TextBox x:Name="LockPedalEffectStrengthTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockPedalEffectsControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Hz" />
                        <TextBox x:Name="LockPedalEffectFrequencyTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockPedalEffectsControl_LostFocus" />
                        <TextBlock Margin="0,4,6,8"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Duration ms" />
                        <TextBox x:Name="LockPedalEffectDurationTextBox"
                                 Width="72"
                                 Margin="0,0,8,8"
                                 LostFocus="MockPedalEffectsControl_LostFocus" />
                    </WrapPanel>
                    <TextBlock x:Name="MockPedalEffectsStatusText"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               TextWrapping="Wrap" />
                    <ItemsControl x:Name="MockPedalEffectsItemsControl"
                                  Margin="0,10,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Margin="0,0,0,8"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="{Binding}"
                                           TextWrapping="Wrap" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border x:Name="SettingsPanel"
                Style="{StaticResource CardBorderStyle}"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Settings" />
                <CheckBox x:Name="SettingsLightThemeCheckBox"
                          Margin="0,12,0,0"
                          Checked="ThemeSettingCheckBox_Changed"
                          Content="Use light theme"
                          Unchecked="ThemeSettingCheckBox_Changed" />
                <Button Width="190"
                        Margin="0,14,0,0"
                        HorizontalAlignment="Left"
                        Click="ResetProfileButton_Click"
                        Content="Reset Current Rig Defaults" />
                <TextBlock x:Name="SettingsStatusText"
                           Margin="0,14,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}" />
                <TextBlock x:Name="SettingsPathText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}" />
                <TextBlock x:Name="RuntimePrerequisiteText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}" />
            </StackPanel>
        </Border>

        <Border x:Name="DiagnosticsPanel"
                Style="{StaticResource CardBorderStyle}"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock FontSize="18"
                           FontWeight="SemiBold"
                           Text="Runtime Diagnostics" />
                <WrapPanel Margin="0,14,0,0">
                    <Button Width="150"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Left"
                            Click="RefreshDiagnosticsButton_Click"
                            Content="Refresh Diagnostics" />
                    <Button Width="150"
                            Margin="0,0,8,0"
                            HorizontalAlignment="Left"
                            Click="ExportSupportBundleButton_Click"
                            Content="Export Support Bundle" />
                    <Button Width="150"
                            HorizontalAlignment="Left"
                            Click="CopyDiagnosticsButton_Click"
                            Content="Copy Report" />
                </WrapPanel>
                <CheckBox x:Name="ExtendedSupportBundleDiagnosticsCheckBox"
                          Margin="0,12,0,0"
                          Content="Include extended diagnostics in support bundles (private IPs only; serials, raw USB payloads, hostnames, and process IDs stay redacted)" />
                <CheckBox x:Name="RoadTextureFlightRecorderCheckBox"
                          Margin="0,14,0,0"
                          Checked="RoadTextureFlightRecorderCheckBox_Changed"
                          Content="Record road texture flight recorder"
                          Unchecked="RoadTextureFlightRecorderCheckBox_Changed" />
                <TextBlock x:Name="RoadTextureFlightRecorderStatusText"
                           Margin="0,8,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           TextWrapping="Wrap" />
                <TextBlock x:Name="DiagnosticsSummaryText"
                           Margin="0,14,0,0"
                           Foreground="{DynamicResource AppMutedTextBrush}" />
                <ItemsControl x:Name="DiagnosticsItemsControl"
                              Margin="0,14,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,0,8"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
