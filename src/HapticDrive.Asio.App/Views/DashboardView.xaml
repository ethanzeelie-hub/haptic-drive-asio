<UserControl x:Class="HapticDrive.Asio.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="420"
             d:DesignWidth="980">
    <StackPanel>
        <UniformGrid Columns="4"
                     Margin="0,0,0,24">
            <Border Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Output Mode" />
                    <TextBlock x:Name="OutputModeValueText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="Not configured" />
                    <TextBlock x:Name="OutputModeDetailText"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Null output remains the safe default until hardware is explicitly selected." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Haptics" />
                    <TextBlock x:Name="HapticsStateText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="Stopped" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Live UDP or replay feeds the output-owned haptic pipeline; Null output remains default." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="UDP Listener" />
                    <TextBlock x:Name="UdpListenerValueText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="Starting" />
                    <TextBlock x:Name="UdpListenerDetailText"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Default port 20778." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Packets" />
                    <TextBlock x:Name="PacketCountValueText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="0" />
                    <TextBlock x:Name="PacketRateDetailText"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="0.00 packets/s" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Forwarding" />
                    <TextBlock x:Name="ForwardingValueText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="Disabled" />
                    <TextBlock x:Name="ForwardingDetailText"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="No destinations configured." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="F1 25 Parser" />
                    <TextBlock x:Name="HeaderParserValueText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="Waiting" />
                    <TextBlock x:Name="HeaderParserDetailText"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="No packets parsed yet." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="VehicleState" />
                    <TextBlock x:Name="VehicleStateValueText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="Waiting" />
                    <TextBlock x:Name="VehicleStateDetailText"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="No vehicle samples mapped yet." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource MetricCardBorderStyle}">
                <StackPanel>
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Recording" />
                    <TextBlock x:Name="RecordingValueText"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Text="Idle" />
                    <TextBlock x:Name="RecordingDetailText"
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Ready to capture raw UDP packets." />
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border x:Name="DashboardSummaryPanel"
                Style="{StaticResource CardBorderStyle}"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeadingTextBlockStyle}"
                           Text="Ready Checklist" />
                <TextBlock x:Name="DashboardWorkflowStatusText"
                           Margin="0,10,0,0"
                           Style="{StaticResource MutedTextBlockStyle}" />
                <TextBlock Margin="0,16,0,0"
                           FontWeight="SemiBold"
                           Text="Next Step" />
                <TextBlock x:Name="DashboardNextStepText"
                           Margin="0,8,0,0"
                           Style="{StaticResource MutedTextBlockStyle}"
                           TextWrapping="Wrap" />
                <ItemsControl x:Name="DashboardChecklistItemsControl"
                              Margin="0,14,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,0,8"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="{Binding}"
                                       TextWrapping="Wrap" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
