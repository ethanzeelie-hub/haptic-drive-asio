<UserControl x:Class="HapticDrive.Asio.App.Views.EffectsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="760"
             d:DesignWidth="980">
    <StackPanel x:Name="EffectsPanel">
        <Border Style="{StaticResource CardBorderStyle}">
            <StackPanel>
                <TextBlock Style="{StaticResource SectionHeadingTextBlockStyle}"
                           Text="Effects" />
                <TextBlock Margin="0,8,0,0"
                           Style="{StaticResource MutedTextBlockStyle}"
                           Text="Normal tuning is grouped by hardware output. BST-1 routes through ASIO/audio; P-HPR pedals use the separate direct actuator path." />

                <Border Margin="0,18,0,0"
                        Padding="16"
                        Background="{DynamicResource AppSurfaceAltBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Text="Descriptor-Driven Effect Settings" />
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextBlockStyle}"
                                   Text="This list is generated from the effect registry so new effects appear here without a MainWindow switch-case or manual page wiring." />
                        <ItemsControl x:Name="GeneratedEffectSettingsItemsControl"
                                      Margin="0,12,0,0"
                                      ItemsSource="{Binding Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10"
                                            Padding="12"
                                            Background="{DynamicResource AppSurfaceBrush}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                        <StackPanel>
                                            <DockPanel LastChildFill="False">
                                                <StackPanel DockPanel.Dock="Left">
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding DisplayName}" />
                                                    <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                                               Text="{Binding EffectKey}" />
                                                </StackPanel>
                                                <Button DockPanel.Dock="Right"
                                                        Style="{StaticResource TopBarButtonStyle}"
                                                        Command="{Binding ResetToDefaultsCommand}"
                                                        Content="Reset To Defaults" />
                                            </DockPanel>
                                            <TextBlock Margin="0,8,0,0"
                                                       Style="{StaticResource MutedTextBlockStyle}"
                                                       Text="{Binding Category}" />
                                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                                       Text="{Binding RequiredSignalsText}" />
                                            <TextBlock Margin="0,6,0,0"
                                                       Style="{StaticResource MutedTextBlockStyle}"
                                                       Text="{Binding ValidationText}" />
                                            <ItemsControl Margin="0,8,0,0"
                                                          ItemsSource="{Binding Parameters}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,0,0,4">
                                                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                                                       Text="{Binding DisplayName}" />
                                                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                                                       Text="{Binding Unit, StringFormat=Unit: {0}}" />
                                                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                                                       Text="{Binding CurrentValue, StringFormat={}{0} current}" />
                                                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                                                       Text="{Binding DefaultValue, StringFormat={}{0} default}" />
                                                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                                                       Text="{Binding Minimum, StringFormat={}{0} min}" />
                                                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                                                       Text="{Binding Maximum, StringFormat={}{0} max}" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Margin="0,18,0,0"
                        Padding="16"
                        Background="{DynamicResource AppSurfaceAltBrush}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Text="Shared / Global Effect Settings" />
                        <CheckBox x:Name="SharedRoadSignalEnabledCheckBox"
                                  Margin="0,10,0,0"
                                  Checked="TuningControl_Changed"
                                  Content="Enable road texture signal"
                                  Unchecked="TuningControl_Changed" />
                        <WrapPanel Margin="0,12,0,0">
                            <TextBlock Margin="0,4,6,8"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Gear shift master duration ms" />
                            <TextBox x:Name="NormalPhprGearDurationTextBox"
                                     Width="84"
                                     Margin="0,0,12,8"
                                     Style="{StaticResource FieldTextBoxStyle}"
                                     LostFocus="PhprPedalsControl_LostFocus" />
                            <TextBlock Margin="0,4,0,8"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Shared by brake P-HPR, throttle P-HPR, Direct Paddle Gear Bench, and BST-1 sync mode." />
                        </WrapPanel>
                        <TextBlock Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextBlockStyle}"
                                   Text="Road texture minimum speed gate" />
                        <Slider x:Name="RoadTextureMinimumSpeedSlider"
                                Maximum="80"
                                Minimum="0"
                                ValueChanged="TuningControl_Changed" />
                        <TextBlock x:Name="RoadTextureMinimumSpeedValueText"
                                   Style="{StaticResource MutedTextBlockStyle}" />
                        <TextBlock x:Name="SharedRoadSignalStatusText"
                                   Margin="0,8,0,0"
                                   Style="{StaticResource MutedTextBlockStyle}" />
                        <TextBlock Margin="0,6,0,0"
                                   Style="{StaticResource MutedTextBlockStyle}"
                                   Text="Gear effects are pulse-like and use duration. Road texture is a continuous telemetry/synthetic signal; it uses shared road signal tuning and gear-priority ducking instead of a normal pulse duration." />
                    </StackPanel>
                </Border>

                <TextBlock Margin="0,22,0,0"
                           Style="{StaticResource SectionHeadingTextBlockStyle}"
                           Text="BST-1 Seat Shaker" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource MutedTextBlockStyle}"
                           Text="ASIO/audio output through the selected bass-shaker channel." />
                <UniformGrid Columns="2"
                             Margin="0,12,0,0">
                    <Border Margin="0,0,10,12"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Gear Shift" />
                            <CheckBox x:Name="GearShiftEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="TuningControl_Changed"
                                      Content="Telemetry gear pulse enabled"
                                      Unchecked="TuningControl_Changed" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Audio gain" />
                            <Slider x:Name="GearShiftGainSlider"
                                    Maximum="1"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="GearShiftGainValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Telemetry pulse duration" />
                            <Slider x:Name="GearShiftDurationSlider"
                                    Maximum="250"
                                    Minimum="10"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="GearShiftDurationValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <CheckBox x:Name="Bst1PaddleGearPulseEnabledCheckBox"
                                      Margin="0,12,0,0"
                                      Checked="Bst1PaddleGearPulseControl_Changed"
                                      Content="Enable local paddle BST-1 gear pulse"
                                      Unchecked="Bst1PaddleGearPulseControl_Changed" />
                            <WrapPanel Margin="0,8,0,0">
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Strength %" />
                                <TextBox x:Name="Bst1PaddleGearStrengthTextBox"
                                         Width="72"
                                         Margin="0,0,10,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="Bst1PaddleGearPulseControl_LostFocus" />
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Hz" />
                                <TextBox x:Name="Bst1PaddleGearFrequencyTextBox"
                                         Width="72"
                                         Margin="0,0,10,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="Bst1PaddleGearPulseControl_LostFocus" />
                                <CheckBox x:Name="Bst1PaddleGearSyncDurationCheckBox"
                                          Margin="0,4,10,8"
                                          Checked="Bst1PaddleGearPulseControl_Changed"
                                          Content="Use shared duration"
                                          Unchecked="Bst1PaddleGearPulseControl_Changed" />
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Custom ms" />
                                <TextBox x:Name="Bst1PaddleGearDurationTextBox"
                                         Width="72"
                                         Margin="0,0,10,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="Bst1PaddleGearPulseControl_LostFocus" />
                            </WrapPanel>
                            <TextBlock x:Name="Bst1PaddleGearEffectiveDurationText"
                                       Margin="0,4,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock x:Name="GearShiftEffectStateText"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Idle" />
                            <TextBlock x:Name="GearShiftEffectDetailText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Waiting for gear telemetry." />
                            <TextBlock x:Name="GearShiftEffectDefaultsText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Conservative defaults pending." />
                        </StackPanel>
                    </Border>

                    <Border Margin="10,0,0,12"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Road Texture" />
                            <CheckBox x:Name="Bst1RoadOutputEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="TuningControl_Changed"
                                      Content="Enable BST-1 road output"
                                      Unchecked="TuningControl_Changed" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="BST-1 / ASIO road output gain" />
                            <Slider x:Name="RoadTextureGainSlider"
                                    Maximum="1"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="RoadTextureGainValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Low-speed frequency Hz" />
                            <Slider x:Name="RoadTextureLowSpeedFrequencySlider"
                                    Maximum="70"
                                    Minimum="20"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="RoadTextureLowSpeedFrequencyValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="High-speed frequency Hz" />
                            <Slider x:Name="RoadTextureHighSpeedFrequencySlider"
                                    Maximum="90"
                                    Minimum="30"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="RoadTextureHighSpeedFrequencyValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Speed reference km/h" />
                            <Slider x:Name="RoadTextureSpeedReferenceSlider"
                                    Maximum="360"
                                    Minimum="120"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="RoadTextureSpeedReferenceValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Speed-frequency influence" />
                            <Slider x:Name="RoadTextureSpeedFrequencyInfluenceSlider"
                                    Maximum="1"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="RoadTextureSpeedFrequencyInfluenceValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Grain / texture amount" />
                            <Slider x:Name="RoadTextureGrainAmountSlider"
                                    Maximum="0.6"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="RoadTextureGrainAmountValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock x:Name="RoadTextureEffectStateText"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Idle" />
                            <TextBlock x:Name="RoadTextureEffectDetailText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Waiting for surface telemetry." />
                            <TextBlock x:Name="RoadTextureEffectDefaultsText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Conservative defaults pending." />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,10,12"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Engine Vibration" />
                            <CheckBox x:Name="EngineEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="TuningControl_Changed"
                                      Content="Engine vibration enabled"
                                      Unchecked="TuningControl_Changed" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Gain" />
                            <Slider x:Name="EngineGainSlider"
                                    Maximum="1"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="EngineGainValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="RPM frequency bounds" />
                            <Slider x:Name="EngineMinimumFrequencySlider"
                                    Maximum="80"
                                    Minimum="15"
                                    ValueChanged="TuningControl_Changed" />
                            <Slider x:Name="EngineMaximumFrequencySlider"
                                    Maximum="120"
                                    Minimum="20"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="EngineFrequencyValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock x:Name="EngineEffectStateText"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Idle" />
                            <TextBlock x:Name="EngineEffectDetailText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Waiting for RPM telemetry." />
                            <TextBlock x:Name="EngineEffectDefaultsText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Conservative defaults pending." />
                        </StackPanel>
                    </Border>

                    <Border Margin="10,0,0,12"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Kerb" />
                            <CheckBox x:Name="KerbEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="TuningControl_Changed"
                                      Content="Kerb enabled"
                                      Unchecked="TuningControl_Changed" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Gain" />
                            <Slider x:Name="KerbGainSlider"
                                    Maximum="1"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="KerbGainValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Base frequency" />
                            <Slider x:Name="KerbBaseFrequencySlider"
                                    Maximum="120"
                                    Minimum="5"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="KerbFrequencyValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock x:Name="KerbEffectStateText"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Idle" />
                            <TextBlock x:Name="KerbEffectDetailText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Waiting for surface telemetry." />
                            <TextBlock x:Name="KerbEffectDefaultsText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Conservative defaults pending." />
                        </StackPanel>
                    </Border>

                    <Border Margin="0,0,10,0"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Impact" />
                            <CheckBox x:Name="ImpactEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="TuningControl_Changed"
                                      Content="Impact enabled"
                                      Unchecked="TuningControl_Changed" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Gain" />
                            <Slider x:Name="ImpactGainSlider"
                                    Maximum="1"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="ImpactGainValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Pulse duration" />
                            <Slider x:Name="ImpactDurationSlider"
                                    Maximum="300"
                                    Minimum="10"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="ImpactDurationValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock x:Name="ImpactEffectStateText"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Idle" />
                            <TextBlock x:Name="ImpactEffectDetailText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Waiting for impact telemetry." />
                            <TextBlock x:Name="ImpactEffectDefaultsText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Conservative defaults pending." />
                        </StackPanel>
                    </Border>

                    <Border Margin="10,0,0,0"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Wheel Slip / Wheel Lock" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Slip uses wheel slip ratio and angle. Lock watches low wheel speed under braking." />
                            <TextBlock Margin="0,12,0,0"
                                       FontWeight="SemiBold"
                                       Text="Wheel Slip" />
                            <CheckBox x:Name="SlipWheelSlipEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="TuningControl_Changed"
                                      Content="Wheel slip enabled"
                                      Unchecked="TuningControl_Changed" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Slip gain" />
                            <Slider x:Name="SlipWheelSlipGainSlider"
                                    Maximum="1"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="SlipWheelSlipGainValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Slip frequency" />
                            <Slider x:Name="SlipWheelSlipFrequencySlider"
                                    Maximum="90"
                                    Minimum="20"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="SlipWheelSlipFrequencyValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Slip roughness" />
                            <Slider x:Name="SlipWheelSlipNoiseSlider"
                                    Maximum="1"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="SlipWheelSlipNoiseValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Slip ratio threshold" />
                            <Slider x:Name="SlipThresholdSlider"
                                    Maximum="1"
                                    Minimum="0.01"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="SlipThresholdValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <Border Margin="0,12,0,0"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,1,0,0" />
                            <TextBlock Margin="0,12,0,0"
                                       FontWeight="SemiBold"
                                       Text="Wheel Lock" />
                            <CheckBox x:Name="SlipWheelLockEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="TuningControl_Changed"
                                      Content="Wheel lock enabled"
                                      Unchecked="TuningControl_Changed" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Lock gain" />
                            <Slider x:Name="SlipWheelLockGainSlider"
                                    Maximum="1"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="SlipWheelLockGainValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Lock frequency" />
                            <Slider x:Name="SlipWheelLockFrequencySlider"
                                    Maximum="90"
                                    Minimum="20"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="SlipWheelLockFrequencyValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Lock roughness" />
                            <Slider x:Name="SlipWheelLockNoiseSlider"
                                    Maximum="1"
                                    Minimum="0"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="SlipWheelLockNoiseValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Lock sensitivity" />
                            <Slider x:Name="SlipWheelLockSensitivitySlider"
                                    Maximum="0.95"
                                    Minimum="0.05"
                                    ValueChanged="TuningControl_Changed" />
                            <TextBlock x:Name="SlipWheelLockSensitivityValueText"
                                       Style="{StaticResource MutedTextBlockStyle}" />
                            <TextBlock x:Name="SlipEffectStateText"
                                       Margin="0,12,0,0"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Idle" />
                            <TextBlock x:Name="SlipEffectDetailText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Waiting for Motion Ex slip telemetry." />
                            <TextBlock x:Name="SlipEffectDefaultsText"
                                       Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Conservative defaults pending." />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <TextBlock Margin="0,22,0,0"
                           Style="{StaticResource SectionHeadingTextBlockStyle}"
                           Text="Brake P-HPR" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource MutedTextBlockStyle}"
                           Text="Direct actuator output. Wheel lock belongs here by default; throttle-only slip stays with the throttle pedal." />
                <UniformGrid Columns="3"
                             Margin="0,12,0,0">
                    <Border Margin="0,0,10,0"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Gear Shift" />
                            <CheckBox x:Name="NormalPhprBrakeEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="PhprPedalsControl_Changed"
                                      Unchecked="PhprPedalsControl_Changed"
                                      Content="Enabled" />
                            <WrapPanel Margin="0,8,0,0">
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Strength %" />
                                <TextBox x:Name="NormalPhprBrakeStrengthTextBox"
                                         Width="64"
                                         Margin="0,0,8,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="PhprPedalsControl_LostFocus" />
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Hz" />
                                <TextBox x:Name="NormalPhprBrakeFrequencyTextBox"
                                         Width="64"
                                         Margin="0,0,8,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="PhprPedalsControl_LostFocus" />
                                <TextBlock Visibility="Collapsed"
                                           Text="ms" />
                                <TextBox x:Name="NormalPhprBrakeDurationTextBox"
                                         Width="72"
                                         Visibility="Collapsed"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="PhprPedalsControl_LostFocus" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="5,0,5,0"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Road Texture" />
                            <CheckBox x:Name="RealRoadVibrationEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="RealPhprDirectControlCheckBox_Changed"
                                      Unchecked="RealPhprDirectControlCheckBox_Changed"
                                      Content="Enable real road vibration" />
                            <CheckBox x:Name="RealRoadBrakeEnabledCheckBox"
                                      Margin="0,8,0,0"
                                      Checked="RealPhprDirectControlCheckBox_Changed"
                                      Unchecked="RealPhprDirectControlCheckBox_Changed"
                                      Content="Brake road texture enabled" />
                            <WrapPanel Margin="0,8,0,0">
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Output scale %" />
                                <TextBox x:Name="RealRoadBrakeStrengthTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="RealPhprDirectControl_LostFocus" />
                            </WrapPanel>
                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Linked to the shared RoadTextureSignal. No normal pulse duration." />
                        </StackPanel>
                    </Border>

                    <Border Margin="10,0,0,0"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Wheel Lock" />
                            <CheckBox x:Name="RealLockEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="RealPhprDirectControlCheckBox_Changed"
                                      Unchecked="RealPhprDirectControlCheckBox_Changed"
                                      Content="Brake wheel lock enabled" />
                            <WrapPanel Margin="0,8,0,0">
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Strength %" />
                                <TextBox x:Name="RealLockStrengthTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="RealPhprDirectControl_LostFocus" />
                            </WrapPanel>
                            <WrapPanel Margin="0,0,0,0">
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Texture cadence ms" />
                                <TextBox x:Name="RealLockCadenceTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="RealPhprDirectControl_LostFocus" />
                            </WrapPanel>
                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Lower cadence gives a tighter/faster lock texture. Frequency range, duration, and target remain in Advanced." />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <TextBlock Margin="0,22,0,0"
                           Style="{StaticResource SectionHeadingTextBlockStyle}"
                           Text="Throttle P-HPR" />
                <TextBlock Margin="0,6,0,0"
                           Style="{StaticResource MutedTextBlockStyle}"
                           Text="Direct actuator output. Wheel slip belongs here by default; brake-only lock stays with the brake pedal." />
                <UniformGrid Columns="3"
                             Margin="0,12,0,0">
                    <Border Margin="0,0,10,0"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Gear Shift" />
                            <CheckBox x:Name="NormalPhprThrottleEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="PhprPedalsControl_Changed"
                                      Unchecked="PhprPedalsControl_Changed"
                                      Content="Enabled" />
                            <WrapPanel Margin="0,8,0,0">
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Strength %" />
                                <TextBox x:Name="NormalPhprThrottleStrengthTextBox"
                                         Width="64"
                                         Margin="0,0,8,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="PhprPedalsControl_LostFocus" />
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Hz" />
                                <TextBox x:Name="NormalPhprThrottleFrequencyTextBox"
                                         Width="64"
                                         Margin="0,0,8,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="PhprPedalsControl_LostFocus" />
                                <TextBlock Visibility="Collapsed"
                                           Text="ms" />
                                <TextBox x:Name="NormalPhprThrottleDurationTextBox"
                                         Width="72"
                                         Visibility="Collapsed"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="PhprPedalsControl_LostFocus" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Margin="5,0,5,0"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Road Texture" />
                            <CheckBox x:Name="RealRoadThrottleEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="RealPhprDirectControlCheckBox_Changed"
                                      Unchecked="RealPhprDirectControlCheckBox_Changed"
                                      Content="Throttle road texture enabled" />
                            <WrapPanel Margin="0,8,0,0">
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Output scale %" />
                                <TextBox x:Name="RealRoadThrottleStrengthTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="RealPhprDirectControl_LostFocus" />
                            </WrapPanel>
                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Linked to the shared RoadTextureSignal. No normal pulse duration." />
                        </StackPanel>
                    </Border>

                    <Border Margin="10,0,0,0"
                            Padding="16"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock FontWeight="SemiBold"
                                       Text="Wheel Slip" />
                            <CheckBox x:Name="RealSlipEnabledCheckBox"
                                      Margin="0,10,0,0"
                                      Checked="RealPhprDirectControlCheckBox_Changed"
                                      Unchecked="RealPhprDirectControlCheckBox_Changed"
                                      Content="Throttle wheel slip enabled" />
                            <WrapPanel Margin="0,8,0,0">
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Strength %" />
                                <TextBox x:Name="RealSlipStrengthTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="RealPhprDirectControl_LostFocus" />
                            </WrapPanel>
                            <WrapPanel Margin="0,0,0,0">
                                <TextBlock Margin="0,4,6,8"
                                           Style="{StaticResource MutedTextBlockStyle}"
                                           Text="Texture cadence ms" />
                                <TextBox x:Name="RealSlipCadenceTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         Style="{StaticResource FieldTextBoxStyle}"
                                         LostFocus="RealPhprDirectControl_LostFocus" />
                            </WrapPanel>
                            <TextBlock Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Lower cadence gives a tighter/faster slip texture. Frequency range, duration, and target remain in Advanced." />
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <TextBlock Margin="0,16,0,0"
                           Style="{StaticResource MutedTextBlockStyle}"
                           Text="These defaults are not physical shaker or P-HPR calibration; final feel, safe gain, latency, and tuning require local hardware testing." />
            </StackPanel>
        </Border>
    </StackPanel>
</UserControl>
