                                           Text="Duration ms" />
                                <TextBox x:Name="RoadPedalEffectDurationTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         LostFocus="MockPedalEffectsControl_LostFocus" />
                            </WrapPanel>
                            <WrapPanel Margin="0,2,0,0">
                                <TextBlock Width="96"
                                           Margin="0,4,8,8"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="Wheel Slip" />
                                <CheckBox x:Name="SlipPedalEffectEnabledCheckBox"
                                          Margin="0,4,12,8"
                                          Checked="MockPedalEffectsControl_Changed"
                                          Unchecked="MockPedalEffectsControl_Changed"
                                          Content="Enabled" />
                                <ComboBox x:Name="SlipPedalEffectTargetComboBox"
                                          Width="150"
                                          Margin="0,0,8,8"
                                          SelectionChanged="MockPedalEffectsControl_Changed" />
                                <TextBlock Margin="0,4,6,8"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Strength %" />
                                <TextBox x:Name="SlipPedalEffectStrengthTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         LostFocus="MockPedalEffectsControl_LostFocus" />
                                <TextBlock Margin="0,4,6,8"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Hz" />
                                <TextBox x:Name="SlipPedalEffectFrequencyTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         LostFocus="MockPedalEffectsControl_LostFocus" />
                                <TextBlock Margin="0,4,6,8"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Duration ms" />
                                <TextBox x:Name="SlipPedalEffectDurationTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         LostFocus="MockPedalEffectsControl_LostFocus" />
                            </WrapPanel>
                            <WrapPanel Margin="0,2,0,0">
                                <TextBlock Width="96"
                                           Margin="0,4,8,8"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="Wheel Lock" />
                                <CheckBox x:Name="LockPedalEffectEnabledCheckBox"
                                          Margin="0,4,12,8"
                                          Checked="MockPedalEffectsControl_Changed"
                                          Unchecked="MockPedalEffectsControl_Changed"
                                          Content="Enabled" />
                                <ComboBox x:Name="LockPedalEffectTargetComboBox"
                                          Width="150"
                                          Margin="0,0,8,8"
                                          SelectionChanged="MockPedalEffectsControl_Changed" />
                                <TextBlock Margin="0,4,6,8"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Strength %" />
                                <TextBox x:Name="LockPedalEffectStrengthTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         LostFocus="MockPedalEffectsControl_LostFocus" />
                                <TextBlock Margin="0,4,6,8"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Hz" />
                                <TextBox x:Name="LockPedalEffectFrequencyTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         LostFocus="MockPedalEffectsControl_LostFocus" />
                                <TextBlock Margin="0,4,6,8"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Duration ms" />
                                <TextBox x:Name="LockPedalEffectDurationTextBox"
                                         Width="72"
                                         Margin="0,0,8,8"
                                         LostFocus="MockPedalEffectsControl_LostFocus" />
                            </WrapPanel>
                            <TextBlock x:Name="MockPedalEffectsStatusText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       TextWrapping="Wrap" />
                            <ItemsControl x:Name="MockPedalEffectsItemsControl"
                                          Margin="0,10,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,8"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   Text="{Binding}"
                                                   TextWrapping="Wrap" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border x:Name="SettingsPanel"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Settings" />
                            <CheckBox x:Name="SettingsLightThemeCheckBox"
                                      Margin="0,12,0,0"
                                      Checked="ThemeSettingCheckBox_Changed"
                                      Content="Use light theme"
                                      Unchecked="ThemeSettingCheckBox_Changed" />
                            <Button Width="190"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="ResetProfileButton_Click"
                                    Content="Reset Current Rig Defaults" />
                            <TextBlock x:Name="SettingsStatusText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="SettingsPathText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="RuntimePrerequisiteText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="DiagnosticsPanel"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Runtime Diagnostics" />
                            <WrapPanel Margin="0,14,0,0">
                                <Button Width="150"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Left"
                                        Click="RefreshDiagnosticsButton_Click"
                                        Content="Refresh Diagnostics" />
                                <Button Width="150"
                                        HorizontalAlignment="Left"
                                        Click="CopyDiagnosticsButton_Click"
                                        Content="Copy Report" />
                            </WrapPanel>
                            <CheckBox x:Name="RoadTextureFlightRecorderCheckBox"
                                      Margin="0,14,0,0"
                                      Checked="RoadTextureFlightRecorderCheckBox_Changed"
                                      Content="Record road texture flight recorder"
                                      Unchecked="RoadTextureFlightRecorderCheckBox_Changed" />
                            <TextBlock x:Name="RoadTextureFlightRecorderStatusText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="DiagnosticsSummaryText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <ItemsControl x:Name="DiagnosticsItemsControl"
                                          Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,8"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock x:Name="PageStatusText"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <ItemsControl x:Name="PageItemsControl"
                                          Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="6"
                                                     Height="6"
                                                     VerticalAlignment="Top"
                                                     Margin="0,7,0,0"
                                                     Fill="{DynamicResource AppAccentBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       Text="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource AppChromeBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterStatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="Ready" />
            </Grid>
        </Border>
    </Grid>
</Window>
