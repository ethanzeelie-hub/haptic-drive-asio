<Window x:Class="HapticDrive.Asio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Haptic Drive ASIO"
        Height="780"
        Width="1240"
        MinHeight="640"
        MinWidth="980"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="68" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{DynamicResource AppTopBarBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock Style="{StaticResource PageKickerTextBlockStyle}"
                               VerticalAlignment="Center"
                               Text="READY" />
                    <Border Width="1"
                            Height="18"
                            Margin="14,0"
                            Background="{DynamicResource AppBorderBrush}" />
                    <TextBlock x:Name="TopBarContextText"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="Stage 18 pre-shaker readiness" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Margin="0,0,12,0"
                            Style="{StaticResource TopStatusBadgeStyle}">
                        <TextBlock x:Name="TelemetryStatusText"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="UDP: starting" />
                    </Border>
                    <Button x:Name="StartStopButton"
                            Margin="0,0,8,0"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="StartStopButton_Click"
                            Content="Start Haptics" />
                    <Button x:Name="StartRecordingButton"
                            Margin="0,0,8,0"
                            Style="{StaticResource TopBarButtonStyle}"
                            Click="StartRecordingButton_Click"
                            Content="Start Recording" />
                    <Button x:Name="EmergencyMuteButton"
                            Margin="0,0,8,0"
                            Style="{StaticResource DangerButtonStyle}"
                            Click="EmergencyMuteButton_Click"
                            Content="Emergency Mute" />
                    <Button x:Name="ThemeButton"
                            Style="{StaticResource TopBarButtonStyle}"
                            Click="ThemeButton_Click"
                            Content="Theme: Dark" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource AppSidebarBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top"
                                Margin="18,18,18,18">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34"
                                    Height="34"
                                    Background="{DynamicResource AppAccentBrush}"
                                    CornerRadius="{StaticResource AppControlCornerRadius}">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Text="H" />
                            </Border>
                            <StackPanel Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="15"
                                           FontWeight="Bold"
                                           Text="Haptic Drive" />
                                <TextBlock Style="{StaticResource PageKickerTextBlockStyle}"
                                           Text="ASIO control" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Margin="0,22,0,8"
                                   Style="{StaticResource PageKickerTextBlockStyle}"
                                   Text="WORKSPACE" />
                    </StackPanel>
                    <ListBox x:Name="NavigationList"
                             Margin="12,0,12,16"
                             ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}"
                             Style="{StaticResource SidebarListBoxStyle}"
                             SelectionChanged="NavigationList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Padding="12,10"
                                           FontWeight="SemiBold"
                                           Text="{Binding NavigationLabel}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Padding="28,24,28,28"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageKickerTextBlockStyle}"
                               Text="CONTROL PANEL" />
                    <TextBlock x:Name="PageTitleText"
                               Margin="0,4,0,0"
                               FontSize="30"
                               FontWeight="Bold" />
                    <TextBlock x:Name="PageSummaryText"
                               Margin="0,8,0,22"
                               FontSize="15"
                               Foreground="{DynamicResource AppMutedTextBrush}" />

                    <UniformGrid Columns="4"
                                 Margin="0,0,0,24">
                        <Border Style="{StaticResource MetricCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Output Mode" />
                                <TextBlock x:Name="OutputModeValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Not configured" />
                                <TextBlock x:Name="OutputModeDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Null output remains the safe default until hardware is explicitly selected." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MetricCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Haptics" />
                                <TextBlock x:Name="HapticsStateText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Stopped" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Live UDP or replay feeds the output-owned haptic pipeline; Null output remains default." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MetricCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="UDP Listener" />
                                <TextBlock x:Name="UdpListenerValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Starting" />
                                <TextBlock x:Name="UdpListenerDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Default port 20778." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MetricCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Packets" />
                                <TextBlock x:Name="PacketCountValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="0" />
                                <TextBlock x:Name="PacketRateDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="0.00 packets/s" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MetricCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Forwarding" />
                                <TextBlock x:Name="ForwardingValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Disabled" />
                                <TextBlock x:Name="ForwardingDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="No destinations configured." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MetricCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="F1 25 Parser" />
                                <TextBlock x:Name="HeaderParserValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Waiting" />
                                <TextBlock x:Name="HeaderParserDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="No packets parsed yet." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MetricCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="VehicleState" />
                                <TextBlock x:Name="VehicleStateValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Waiting" />
                                <TextBlock x:Name="VehicleStateDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="No vehicle samples mapped yet." />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource MetricCardBorderStyle}">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Recording" />
                                <TextBlock x:Name="RecordingValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Idle" />
                                <TextBlock x:Name="RecordingDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Ready to capture raw UDP packets." />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border x:Name="EffectsPanel"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeadingTextBlockStyle}"
                                       Text="Effects" />
                            <TextBlock Margin="0,8,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="Normal tuning is grouped by hardware output. BST-1 routes through ASIO/audio; P-HPR pedals use the separate direct actuator path." />

                            <Border Margin="0,18,0,0"
                                    Padding="16"
                                    Background="{DynamicResource AppSurfaceAltBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                <StackPanel>
                                    <TextBlock FontWeight="SemiBold"
                                               Text="Shared / Global Effect Settings" />
                                    <WrapPanel Margin="0,12,0,0">
                                        <TextBlock Margin="0,4,6,8"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Gear shift master duration ms" />
                                        <TextBox x:Name="NormalPhprGearDurationTextBox"
                                                 Width="84"
                                                 Margin="0,0,12,8"
                                                 Style="{StaticResource FieldTextBoxStyle}"
                                                 LostFocus="PhprPedalsControl_LostFocus" />
                                        <TextBlock Margin="0,4,0,8"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Shared by brake P-HPR, throttle P-HPR, Direct Paddle Gear Bench, and BST-1 sync mode." />
                                    </WrapPanel>
                                    <TextBlock Margin="0,6,0,0"
                                               Style="{StaticResource MutedTextBlockStyle}"
                                               Text="Gear effects are pulse-like and use duration. Road texture is a continuous telemetry/synthetic signal; it uses shared road signal tuning and gear-priority ducking instead of a normal pulse duration." />
                                </StackPanel>
                            </Border>

                            <TextBlock Margin="0,22,0,0"
                                       Style="{StaticResource SectionHeadingTextBlockStyle}"
                                       Text="BST-1 Seat Shaker" />
                            <TextBlock Margin="0,6,0,0"
                                       Style="{StaticResource MutedTextBlockStyle}"
                                       Text="ASIO/audio output through the selected bass-shaker channel." />
                            <UniformGrid Columns="2"
                                         Margin="0,12,0,0">
                                <Border Margin="0,0,10,12"
                                        Padding="16"
                                        Background="{DynamicResource AppSurfaceAltBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Gear Shift" />
                                        <CheckBox x:Name="GearShiftEnabledCheckBox"
                                                  Margin="0,10,0,0"
                                                  Checked="TuningControl_Changed"
                                                  Content="Telemetry gear pulse enabled"
                                                  Unchecked="TuningControl_Changed" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Audio gain" />
                                        <Slider x:Name="GearShiftGainSlider"
                                                Maximum="0.4"
                                                Minimum="0"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="GearShiftGainValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Telemetry pulse duration" />
                                        <Slider x:Name="GearShiftDurationSlider"
                                                Maximum="250"
                                                Minimum="10"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="GearShiftDurationValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <CheckBox x:Name="Bst1PaddleGearPulseEnabledCheckBox"
                                                  Margin="0,12,0,0"
                                                  Checked="Bst1PaddleGearPulseControl_Changed"
                                                  Content="Enable local paddle BST-1 gear pulse"
                                                  Unchecked="Bst1PaddleGearPulseControl_Changed" />
                                        <WrapPanel Margin="0,8,0,0">
                                            <TextBlock Margin="0,4,6,8"
                                                       Style="{StaticResource MutedTextBlockStyle}"
                                                       Text="Strength %" />
                                            <TextBox x:Name="Bst1PaddleGearStrengthTextBox"
                                                     Width="72"
                                                     Margin="0,0,10,8"
                                                     Style="{StaticResource FieldTextBoxStyle}"
                                                     LostFocus="Bst1PaddleGearPulseControl_LostFocus" />
                                            <TextBlock Margin="0,4,6,8"
                                                       Style="{StaticResource MutedTextBlockStyle}"
                                                       Text="Hz" />
                                            <TextBox x:Name="Bst1PaddleGearFrequencyTextBox"
                                                     Width="72"
                                                     Margin="0,0,10,8"
                                                     Style="{StaticResource FieldTextBoxStyle}"
                                                     LostFocus="Bst1PaddleGearPulseControl_LostFocus" />
                                            <CheckBox x:Name="Bst1PaddleGearSyncDurationCheckBox"
                                                      Margin="0,4,10,8"
                                                      Checked="Bst1PaddleGearPulseControl_Changed"
                                                      Content="Use shared duration"
                                                      Unchecked="Bst1PaddleGearPulseControl_Changed" />
                                            <TextBlock Margin="0,4,6,8"
                                                       Style="{StaticResource MutedTextBlockStyle}"
                                                       Text="Custom ms" />
                                            <TextBox x:Name="Bst1PaddleGearDurationTextBox"
                                                     Width="72"
                                                     Margin="0,0,10,8"
                                                     Style="{StaticResource FieldTextBoxStyle}"
                                                     LostFocus="Bst1PaddleGearPulseControl_LostFocus" />
                                        </WrapPanel>
                                        <TextBlock x:Name="Bst1PaddleGearEffectiveDurationText"
                                                   Margin="0,4,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock x:Name="GearShiftEffectStateText"
                                                   Margin="0,12,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Idle" />
                                        <TextBlock x:Name="GearShiftEffectDetailText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Waiting for gear telemetry." />
                                        <TextBlock x:Name="GearShiftEffectDefaultsText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Conservative defaults pending." />
                                    </StackPanel>
                                </Border>

                                <Border Margin="10,0,0,12"
                                        Padding="16"
                                        Background="{DynamicResource AppSurfaceAltBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Road Texture" />
                                        <CheckBox x:Name="RoadTextureEnabledCheckBox"
                                                  Margin="0,10,0,0"
                                                  Checked="TuningControl_Changed"
                                                  Content="Road texture enabled"
                                                  Unchecked="TuningControl_Changed" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Gain" />
                                        <Slider x:Name="RoadTextureGainSlider"
                                                Maximum="0.25"
                                                Minimum="0"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="RoadTextureGainValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Minimum speed gate" />
                                        <Slider x:Name="RoadTextureMinimumSpeedSlider"
                                                Maximum="80"
                                                Minimum="0"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="RoadTextureMinimumSpeedValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock x:Name="RoadTextureEffectStateText"
                                                   Margin="0,12,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Idle" />
                                        <TextBlock x:Name="RoadTextureEffectDetailText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Waiting for surface telemetry." />
                                        <TextBlock x:Name="RoadTextureEffectDefaultsText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Conservative defaults pending." />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,10,12"
                                        Padding="16"
                                        Background="{DynamicResource AppSurfaceAltBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Engine Vibration" />
                                        <CheckBox x:Name="EngineEnabledCheckBox"
                                                  Margin="0,10,0,0"
                                                  Checked="TuningControl_Changed"
                                                  Content="Engine vibration enabled"
                                                  Unchecked="TuningControl_Changed" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Gain" />
                                        <Slider x:Name="EngineGainSlider"
                                                Maximum="0.4"
                                                Minimum="0"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="EngineGainValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="RPM frequency bounds" />
                                        <Slider x:Name="EngineMinimumFrequencySlider"
                                                Maximum="80"
                                                Minimum="15"
                                                ValueChanged="TuningControl_Changed" />
                                        <Slider x:Name="EngineMaximumFrequencySlider"
                                                Maximum="120"
                                                Minimum="20"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="EngineFrequencyValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock x:Name="EngineEffectStateText"
                                                   Margin="0,12,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Idle" />
                                        <TextBlock x:Name="EngineEffectDetailText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Waiting for RPM telemetry." />
                                        <TextBlock x:Name="EngineEffectDefaultsText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Conservative defaults pending." />
                                    </StackPanel>
                                </Border>

                                <Border Margin="10,0,0,12"
                                        Padding="16"
                                        Background="{DynamicResource AppSurfaceAltBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Kerb" />
                                        <CheckBox x:Name="KerbEnabledCheckBox"
                                                  Margin="0,10,0,0"
                                                  Checked="TuningControl_Changed"
                                                  Content="Kerb enabled"
                                                  Unchecked="TuningControl_Changed" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Gain" />
                                        <Slider x:Name="KerbGainSlider"
                                                Maximum="0.4"
                                                Minimum="0"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="KerbGainValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Base frequency" />
                                        <Slider x:Name="KerbBaseFrequencySlider"
                                                Maximum="120"
                                                Minimum="5"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="KerbFrequencyValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock x:Name="KerbEffectStateText"
                                                   Margin="0,12,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Idle" />
                                        <TextBlock x:Name="KerbEffectDetailText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Waiting for surface telemetry." />
                                        <TextBlock x:Name="KerbEffectDefaultsText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Conservative defaults pending." />
                                    </StackPanel>
                                </Border>

                                <Border Margin="0,0,10,0"
                                        Padding="16"
                                        Background="{DynamicResource AppSurfaceAltBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Impact" />
                                        <CheckBox x:Name="ImpactEnabledCheckBox"
                                                  Margin="0,10,0,0"
                                                  Checked="TuningControl_Changed"
                                                  Content="Impact enabled"
                                                  Unchecked="TuningControl_Changed" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Gain" />
                                        <Slider x:Name="ImpactGainSlider"
                                                Maximum="0.4"
                                                Minimum="0"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="ImpactGainValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Pulse duration" />
                                        <Slider x:Name="ImpactDurationSlider"
                                                Maximum="300"
                                                Minimum="10"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="ImpactDurationValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock x:Name="ImpactEffectStateText"
                                                   Margin="0,12,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Idle" />
                                        <TextBlock x:Name="ImpactEffectDetailText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Waiting for impact telemetry." />
                                        <TextBlock x:Name="ImpactEffectDefaultsText"
                                                   Margin="0,6,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Conservative defaults pending." />
                                    </StackPanel>
                                </Border>

                                <Border Margin="10,0,0,0"
                                        Padding="16"
                                        Background="{DynamicResource AppSurfaceAltBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold"
                                                   Text="Wheel Slip / Wheel Lock" />
                                        <CheckBox x:Name="SlipEnabledCheckBox"
                                                  Margin="0,10,0,0"
                                                  Checked="TuningControl_Changed"
                                                  Content="Slip / traction loss enabled"
                                                  Unchecked="TuningControl_Changed" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Gain" />
                                        <Slider x:Name="SlipGainSlider"
                                                Maximum="0.3"
                                                Minimum="0"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="SlipGainValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock Margin="0,8,0,0"
                                                   Style="{StaticResource MutedTextBlockStyle}"
                                                   Text="Slip ratio threshold" />
                                        <Slider x:Name="SlipThresholdSlider"
                                                Maximum="1"
                                                Minimum="0.01"
                                                ValueChanged="TuningControl_Changed" />
                                        <TextBlock x:Name="SlipThresholdValueText"
                                                   Style="{StaticResource MutedTextBlockStyle}" />
                                        <TextBlock x:Name="SlipEffectStateText"
                                                   Margin="0,12,0,0"
                                                   FontSize="18"
                                                   FontWeight="SemiBold"
                                                   Text="Idle" />
                                        <TextBlock x:Name="SlipEffectDetailText"
