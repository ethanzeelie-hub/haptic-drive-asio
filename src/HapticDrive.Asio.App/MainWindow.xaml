<Window x:Class="HapticDrive.Asio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:views="clr-namespace:HapticDrive.Asio.App.Views"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Haptic Drive ASIO"
        Height="780"
        Width="1240"
        MinHeight="640"
        MinWidth="980"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="68" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Grid.ColumnSpan="2"
                Background="{DynamicResource AppTopBarBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock Style="{StaticResource PageKickerTextBlockStyle}"
                               VerticalAlignment="Center"
                               Text="READY" />
                    <Border Width="1"
                            Height="18"
                            Margin="14,0"
                            Background="{DynamicResource AppBorderBrush}" />
                    <TextBlock x:Name="TopBarContextText"
                               VerticalAlignment="Center"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Text="Operational overview" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Margin="0,0,12,0"
                            Style="{StaticResource TopStatusBadgeStyle}">
                        <TextBlock x:Name="TelemetryStatusText"
                                   AutomationProperties.HelpText="Shows whether telemetry is loopback-only or LAN-enabled, plus the current UDP listener state."
                                   AutomationProperties.Name="Telemetry listener status"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="UDP: starting" />
                    </Border>
                    <Border Margin="0,0,12,0"
                            Style="{StaticResource TopStatusBadgeStyle}">
                        <TextBlock x:Name="SafetyStatusText"
                                   AutomationProperties.HelpText="Shows the global output safety interlock state for ASIO, test bench, and P-HPR outputs."
                                   AutomationProperties.Name="Global safety interlock status"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Safety: startup latched" />
                    </Border>
                    <Button x:Name="StartStopButton"
                            Margin="0,0,8,0"
                            AutomationProperties.AccessKey="Alt+S"
                            AutomationProperties.HelpText="Starts or stops the haptics pipeline."
                            AutomationProperties.Name="Start or stop haptics"
                            Style="{StaticResource PrimaryButtonStyle}"
                            TabIndex="0"
                            Click="StartStopButton_Click"
                            Content="Start Haptics" />
                    <Button x:Name="StartRecordingButton"
                            Margin="0,0,8,0"
                            AutomationProperties.AccessKey="Alt+R"
                            AutomationProperties.HelpText="Starts or stops telemetry recording."
                            AutomationProperties.Name="Start or stop recording"
                            Style="{StaticResource TopBarButtonStyle}"
                            TabIndex="1"
                            Click="StartRecordingButton_Click"
                            Content="Start Recording" />
                    <Button x:Name="EmergencyMuteButton"
                            Margin="0,0,8,0"
                            AutomationProperties.AccessKey="Ctrl+Shift+M"
                            AutomationProperties.HelpText="Trips the global output interlock immediately. Shortcut: Control Shift M."
                            AutomationProperties.Name="Emergency mute"
                            Style="{StaticResource DangerButtonStyle}"
                            TabIndex="2"
                            ToolTip="Emergency mute all outputs (Ctrl+Shift+M)"
                            Click="EmergencyMuteButton_Click"
                            Content="Emergency Mute" />
                    <Button x:Name="ResetOutputInterlockButton"
                            Margin="0,0,8,0"
                            AutomationProperties.AccessKey="Ctrl+Shift+R"
                            AutomationProperties.HelpText="Resets the global output interlock after readiness checks pass. Shortcut: Control Shift R."
                            AutomationProperties.Name="Reset output interlock"
                            Style="{StaticResource TopBarButtonStyle}"
                            TabIndex="3"
                            ToolTip="Reset the global output interlock (Ctrl+Shift+R)"
                            Click="ResetOutputInterlockButton_Click"
                            Content="Reset Output Interlock" />
                    <Button x:Name="ThemeButton"
                            AutomationProperties.AccessKey="Alt+T"
                            AutomationProperties.HelpText="Toggles the application theme."
                            AutomationProperties.Name="Toggle theme"
                            Style="{StaticResource TopBarButtonStyle}"
                            TabIndex="4"
                            Click="ThemeButton_Click"
                            Content="Theme: Dark" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource AppSidebarBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top"
                                Margin="18,18,18,18">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34"
                                    Height="34"
                                    Background="{DynamicResource AppAccentBrush}"
                                    CornerRadius="{StaticResource AppControlCornerRadius}">
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="18"
                                           FontWeight="Bold"
                                           Text="H" />
                            </Border>
                            <StackPanel Margin="12,0,0,0"
                                        VerticalAlignment="Center">
                                <TextBlock FontSize="15"
                                           FontWeight="Bold"
                                           Text="Haptic Drive" />
                                <TextBlock Style="{StaticResource PageKickerTextBlockStyle}"
                                           Text="ASIO control" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Margin="0,22,0,8"
                                   Style="{StaticResource PageKickerTextBlockStyle}"
                                   Text="WORKSPACE" />
                    </StackPanel>
                    <ListBox x:Name="NavigationList"
                             Margin="12,0,12,16"
                             ItemContainerStyle="{StaticResource SidebarListBoxItemStyle}"
                             Style="{StaticResource SidebarListBoxStyle}"
                             SelectionChanged="NavigationList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Padding="12,10"
                                           FontWeight="SemiBold"
                                           Text="{Binding NavigationLabel}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Padding="28,24,28,28"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Style="{StaticResource PageKickerTextBlockStyle}"
                               Text="CONTROL PANEL" />
                    <TextBlock x:Name="PageTitleText"
                               Margin="0,4,0,0"
                               FontSize="30"
                               FontWeight="Bold" />
                    <TextBlock x:Name="PageSummaryText"
                               Margin="0,8,0,22"
                               FontSize="15"
                               Foreground="{DynamicResource AppMutedTextBrush}" />

                    <views:DashboardView x:Name="DashboardViewControl"
                                         Margin="0,0,0,24" />

                    <views:EffectsView x:Name="EffectsViewControl"
                                       Margin="0,0,0,24"
                                       Visibility="Collapsed" />

                    <views:RoutingMixerView x:Name="RoutingMixerViewControl"
                                            Margin="0,0,0,24"
                                            Visibility="Collapsed" />

                    <views:TelemetryUdpView x:Name="TelemetryUdpViewControl"
                                            Margin="0,0,0,24"
                                            Visibility="Collapsed" />

                    <views:ProfilesView x:Name="ProfilesViewControl"
                                        Margin="0,0,0,24"
                                        Visibility="Collapsed" />

                    <views:TestingValidationView x:Name="TestingValidationViewControl"
                                                 Margin="0,0,0,24"
                                                 Visibility="Collapsed" />

                    <views:DevicesView x:Name="DevicesViewControl"
                                       Visibility="Collapsed" />

                    <views:AdvancedDiagnosticsView x:Name="AdvancedDiagnosticsViewControl"
                                                   Margin="0,0,0,24"
                                                   Visibility="Collapsed" />

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock x:Name="PageStatusText"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <ItemsControl x:Name="PageItemsControl"
                                          Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="6"
                                                     Height="6"
                                                     VerticalAlignment="Top"
                                                     Margin="0,7,0,0"
                                                     Fill="{DynamicResource AppAccentBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       Text="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource AppChromeBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterStatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="Ready" />
            </Grid>
        </Border>
    </Grid>
</Window>
