<Window x:Class="HapticDrive.Asio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Haptic Drive ASIO"
        Height="760"
        Width="1180"
        MinHeight="640"
        MinWidth="980"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="78" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="Bold"
                               Text="Haptic Drive ASIO" />
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Stage 02 output abstractions - hardware absent, safe by default" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Margin="0,0,12,0"
                            Padding="12,7"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock x:Name="TelemetryStatusText"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="Telemetry: not connected" />
                    </Border>
                    <Button x:Name="StartStopButton"
                            Margin="0,0,8,0"
                            Click="StartStopButton_Click"
                            Content="Start Haptics" />
                    <Button x:Name="EmergencyMuteButton"
                            Margin="0,0,8,0"
                            Background="{DynamicResource AppDangerBrush}"
                            BorderBrush="{DynamicResource AppDangerBrush}"
                            Click="EmergencyMuteButton_Click"
                            Content="Emergency Mute" />
                    <Button x:Name="ThemeButton"
                            Click="ThemeButton_Click"
                            Content="Theme: Dark" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Margin="20,18,20,10"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="WORKSPACE" />
                    <ListBox x:Name="NavigationList"
                             Margin="12,0,12,16"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource AppTextBrush}"
                             SelectionChanged="NavigationList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Padding="12,9"
                                           Text="{Binding NavigationLabel}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Padding="28"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="PageTitleText"
                               FontSize="30"
                               FontWeight="Bold" />
                    <TextBlock x:Name="PageSummaryText"
                               Margin="0,8,0,24"
                               FontSize="15"
                               Foreground="{DynamicResource AppMutedTextBrush}" />

                    <UniformGrid Columns="3"
                                 Margin="0,0,0,24">
                        <Border Margin="0,0,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Output Mode" />
                                <TextBlock x:Name="OutputModeValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Not configured" />
                                <TextBlock x:Name="OutputModeDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Stage 02 adds hardware-absent output devices." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Haptics" />
                                <TextBlock x:Name="HapticsStateText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Stopped" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Controls are placeholders until the pipeline exists." />
                            </StackPanel>
                        </Border>

                        <Border Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Safety" />
                                <TextBlock x:Name="SafetyStateText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Normal" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Emergency mute UI is present before audio is wired." />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock x:Name="PageStatusText"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <ItemsControl x:Name="PageItemsControl"
                                          Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="6"
                                                     Height="6"
                                                     VerticalAlignment="Top"
                                                     Margin="0,7,0,0"
                                                     Fill="{DynamicResource AppAccentBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       Text="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterStatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="Ready - Stage 01 shell only" />
                <CheckBox Grid.Column="1"
                          Content="Minimize to tray on close"
                          IsEnabled="False" />
            </Grid>
        </Border>
    </Grid>
</Window>
