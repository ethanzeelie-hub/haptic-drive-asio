                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Profiles" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Profiles are versioned JSON tuning snapshots stored under local app data. Emergency mute is runtime-only and is not saved." />
                            <TextBlock Margin="0,16,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Profile name" />
                            <TextBox x:Name="ProfileNameTextBox"
                                     MaxWidth="360"
                                     HorizontalAlignment="Left" />
                            <WrapPanel Margin="0,14,0,0">
                                <Button Width="120"
                                        Margin="0,0,8,0"
                                        Click="SaveProfileButton_Click"
                                        Content="Save Profile" />
                                <Button Width="120"
                                        Margin="0,0,8,0"
                                        Click="LoadProfileButton_Click"
                                        Content="Load Profile" />
                                <Button Width="150"
                                        Click="ResetProfileButton_Click"
                                        Content="Reset Defaults" />
                            </WrapPanel>
                            <TextBlock x:Name="ProfileStatusText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="ProfilePathText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="ProfilePhprStatusText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       TextWrapping="Wrap" />
                            <TextBlock x:Name="ProfileValidationText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="SettingsPanel"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Settings" />
                            <CheckBox x:Name="SettingsLightThemeCheckBox"
                                      Margin="0,12,0,0"
                                      Checked="ThemeSettingCheckBox_Changed"
                                      Content="Use light theme"
                                      Unchecked="ThemeSettingCheckBox_Changed" />
                            <Button Width="190"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="ResetProfileButton_Click"
                                    Content="Reset Conservative Defaults" />
                            <TextBlock x:Name="SettingsStatusText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="SettingsPathText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="RuntimePrerequisiteText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="DiagnosticsPanel"
                            Style="{StaticResource CardBorderStyle}"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Runtime Diagnostics" />
                            <WrapPanel Margin="0,14,0,0">
                                <Button Width="150"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Left"
                                        Click="RefreshDiagnosticsButton_Click"
                                        Content="Refresh Diagnostics" />
                                <Button Width="150"
                                        HorizontalAlignment="Left"
                                        Click="CopyDiagnosticsButton_Click"
                                        Content="Copy Report" />
                            </WrapPanel>
                            <TextBlock x:Name="DiagnosticsSummaryText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <ItemsControl x:Name="DiagnosticsItemsControl"
                                          Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,8"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock x:Name="PageStatusText"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <ItemsControl x:Name="PageItemsControl"
                                          Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="6"
                                                     Height="6"
                                                     VerticalAlignment="Top"
                                                     Margin="0,7,0,0"
                                                     Fill="{DynamicResource AppAccentBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       Text="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource AppChromeBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterStatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="Ready - Stage 18 final pre-shaker package" />
            </Grid>
        </Border>
    </Grid>
</Window>
