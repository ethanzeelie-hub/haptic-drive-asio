<Window x:Class="HapticDrive.Asio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Haptic Drive ASIO"
        Height="780"
        Width="1240"
        MinHeight="640"
        MinWidth="980"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="78" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="Bold"
                               Text="Haptic Drive ASIO" />
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Stage 15 first playable mock output" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Margin="0,0,12,0"
                            Padding="12,7"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock x:Name="TelemetryStatusText"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="UDP: starting" />
                    </Border>
                    <Button x:Name="StartStopButton"
                            Margin="0,0,8,0"
                            Click="StartStopButton_Click"
                            Content="Start Haptics" />
                    <Button x:Name="StartRecordingButton"
                            Margin="0,0,8,0"
                            Click="StartRecordingButton_Click"
                            Content="Start Recording" />
                    <Button x:Name="EmergencyMuteButton"
                            Margin="0,0,8,0"
                            Background="{DynamicResource AppDangerBrush}"
                            BorderBrush="{DynamicResource AppDangerBrush}"
                            Click="EmergencyMuteButton_Click"
                            Content="Emergency Mute" />
                    <Button x:Name="ThemeButton"
                            Click="ThemeButton_Click"
                            Content="Theme: Dark" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Margin="20,18,20,10"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="WORKSPACE" />
                    <ListBox x:Name="NavigationList"
                             Margin="12,0,12,16"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource AppTextBrush}"
                             SelectionChanged="NavigationList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Padding="12,9"
                                           Text="{Binding NavigationLabel}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Padding="28"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="PageTitleText"
                               FontSize="30"
                               FontWeight="Bold" />
                    <TextBlock x:Name="PageSummaryText"
                               Margin="0,8,0,24"
                               FontSize="15"
                               Foreground="{DynamicResource AppMutedTextBrush}" />

                    <UniformGrid Columns="4"
                                 Margin="0,0,0,24">
                        <Border Margin="0,0,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Output Mode" />
                                <TextBlock x:Name="OutputModeValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Not configured" />
                                <TextBlock x:Name="OutputModeDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Stage 02 adds hardware-absent output devices." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Haptics" />
                                <TextBlock x:Name="HapticsStateText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Stopped" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Live UDP or replay can feed the mock pipeline; Null output remains default." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="UDP Listener" />
                                <TextBlock x:Name="UdpListenerValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Starting" />
                                <TextBlock x:Name="UdpListenerDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Default port 20778." />
                            </StackPanel>
                        </Border>

                        <Border Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Packets" />
                                <TextBlock x:Name="PacketCountValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="0" />
                                <TextBlock x:Name="PacketRateDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="0.00 packets/s" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Forwarding" />
                                <TextBlock x:Name="ForwardingValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Disabled" />
                                <TextBlock x:Name="ForwardingDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="No destinations configured." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="F1 25 Parser" />
                                <TextBlock x:Name="HeaderParserValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Waiting" />
                                <TextBlock x:Name="HeaderParserDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="No packets parsed yet." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="VehicleState" />
                                <TextBlock x:Name="VehicleStateValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Waiting" />
                                <TextBlock x:Name="VehicleStateDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="No vehicle samples mapped yet." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Recording" />
                                <TextBlock x:Name="RecordingValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Idle" />
                                <TextBlock x:Name="RecordingDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Ready to capture raw UDP packets." />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border x:Name="EffectsPanel"
                            Margin="0,0,0,24"
                            Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Stage 15 Effect Tuning" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Engine, gear shift, kerb, impact, road texture, and slip effects are synthesized from VehicleState telemetry, then rendered through the mixer, safety chain, and Null output." />

                            <UniformGrid Columns="2"
                                         Margin="0,18,0,0">
                                <StackPanel Margin="0,0,24,18">
                                    <CheckBox x:Name="EngineEnabledCheckBox"
                                              Checked="TuningControl_Changed"
                                              Content="Engine vibration enabled"
                                              Unchecked="TuningControl_Changed" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Gain" />
                                    <Slider x:Name="EngineGainSlider"
                                            Maximum="0.4"
                                            Minimum="0"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="EngineGainValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="RPM frequency bounds" />
                                    <Slider x:Name="EngineMinimumFrequencySlider"
                                            Maximum="80"
                                            Minimum="15"
                                            ValueChanged="TuningControl_Changed" />
                                    <Slider x:Name="EngineMaximumFrequencySlider"
                                            Maximum="120"
                                            Minimum="20"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="EngineFrequencyValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                </StackPanel>

                                <StackPanel Margin="0,0,0,18">
                                    <CheckBox x:Name="GearShiftEnabledCheckBox"
                                              Checked="TuningControl_Changed"
                                              Content="Gear shift enabled"
                                              Unchecked="TuningControl_Changed" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Gain" />
                                    <Slider x:Name="GearShiftGainSlider"
                                            Maximum="0.4"
                                            Minimum="0"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="GearShiftGainValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Pulse duration" />
                                    <Slider x:Name="GearShiftDurationSlider"
                                            Maximum="250"
                                            Minimum="10"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="GearShiftDurationValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                </StackPanel>

                                <StackPanel Margin="0,0,24,18">
                                    <CheckBox x:Name="KerbEnabledCheckBox"
                                              Checked="TuningControl_Changed"
                                              Content="Kerb enabled"
                                              Unchecked="TuningControl_Changed" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Gain" />
                                    <Slider x:Name="KerbGainSlider"
                                            Maximum="0.4"
                                            Minimum="0"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="KerbGainValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Base frequency" />
                                    <Slider x:Name="KerbBaseFrequencySlider"
                                            Maximum="120"
                                            Minimum="5"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="KerbFrequencyValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                </StackPanel>

                                <StackPanel Margin="0,0,0,18">
                                    <CheckBox x:Name="ImpactEnabledCheckBox"
                                              Checked="TuningControl_Changed"
                                              Content="Impact enabled"
                                              Unchecked="TuningControl_Changed" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Gain" />
                                    <Slider x:Name="ImpactGainSlider"
                                            Maximum="0.4"
                                            Minimum="0"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="ImpactGainValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Pulse duration" />
                                    <Slider x:Name="ImpactDurationSlider"
                                            Maximum="300"
                                            Minimum="10"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="ImpactDurationValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                </StackPanel>

                                <StackPanel Margin="0,0,24,0">
                                    <CheckBox x:Name="RoadTextureEnabledCheckBox"
                                              Checked="TuningControl_Changed"
                                              Content="Road texture enabled"
                                              Unchecked="TuningControl_Changed" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Gain" />
                                    <Slider x:Name="RoadTextureGainSlider"
                                            Maximum="0.25"
                                            Minimum="0"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="RoadTextureGainValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Minimum speed gate" />
                                    <Slider x:Name="RoadTextureMinimumSpeedSlider"
                                            Maximum="80"
                                            Minimum="0"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="RoadTextureMinimumSpeedValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                </StackPanel>

                                <StackPanel>
                                    <CheckBox x:Name="SlipEnabledCheckBox"
                                              Checked="TuningControl_Changed"
                                              Content="Slip / traction loss enabled"
                                              Unchecked="TuningControl_Changed" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Gain" />
                                    <Slider x:Name="SlipGainSlider"
                                            Maximum="0.3"
                                            Minimum="0"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="SlipGainValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Slip ratio threshold" />
                                    <Slider x:Name="SlipThresholdSlider"
                                            Maximum="1"
                                            Minimum="0.01"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="SlipThresholdValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                </StackPanel>
                            </UniformGrid>

                            <UniformGrid Columns="2"
                                         Margin="0,18,0,0">
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Engine Vibration" />
                                    <TextBlock x:Name="EngineEffectStateText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Idle" />
                                    <TextBlock x:Name="EngineEffectDetailText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Waiting for RPM telemetry." />
                                    <TextBlock x:Name="EngineEffectDefaultsText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Conservative defaults pending." />
                                </StackPanel>

                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Gear Shift" />
                                    <TextBlock x:Name="GearShiftEffectStateText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Idle" />
                                    <TextBlock x:Name="GearShiftEffectDetailText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Waiting for gear telemetry." />
                                    <TextBlock x:Name="GearShiftEffectDefaultsText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Conservative defaults pending." />
                                </StackPanel>

                                <StackPanel Margin="0,18,24,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Kerb" />
                                    <TextBlock x:Name="KerbEffectStateText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Idle" />
                                    <TextBlock x:Name="KerbEffectDetailText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Waiting for surface telemetry." />
                                    <TextBlock x:Name="KerbEffectDefaultsText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Conservative defaults pending." />
                                </StackPanel>

                                <StackPanel Margin="0,18,0,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Impact" />
                                    <TextBlock x:Name="ImpactEffectStateText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Idle" />
                                    <TextBlock x:Name="ImpactEffectDetailText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Waiting for impact telemetry." />
                                    <TextBlock x:Name="ImpactEffectDefaultsText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Conservative defaults pending." />
                                </StackPanel>

                                <StackPanel Margin="0,18,24,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Road Texture" />
                                    <TextBlock x:Name="RoadTextureEffectStateText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Idle" />
                                    <TextBlock x:Name="RoadTextureEffectDetailText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Waiting for surface telemetry." />
                                    <TextBlock x:Name="RoadTextureEffectDefaultsText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Conservative defaults pending." />
                                </StackPanel>

                                <StackPanel Margin="0,18,0,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Slip / Lock" />
                                    <TextBlock x:Name="SlipEffectStateText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Idle" />
                                    <TextBlock x:Name="SlipEffectDetailText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Waiting for Motion Ex slip telemetry." />
                                    <TextBlock x:Name="SlipEffectDefaultsText"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Conservative defaults pending." />
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock Margin="0,16,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="These defaults are not physical shaker calibration; final feel, safe gain, latency, and tuning require local hardware testing." />
                        </StackPanel>
                    </Border>

                    <Border x:Name="TestBenchPanel"
                            Margin="0,0,0,24"
                            Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Synthetic Test Bench" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Render deterministic validation buffers through the Stage 10 mixer, safety chain, and Null output." />

                            <WrapPanel Margin="0,16,0,0"
                                       VerticalAlignment="Center">
                                <StackPanel Width="240"
                                            Margin="0,0,16,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Signal" />
                                    <ComboBox x:Name="TestBenchSignalComboBox"
                                              Margin="0,6,0,0"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="TestBenchSignalComboBox_SelectionChanged" />
                                </StackPanel>

                                <Button x:Name="TestBenchStartStopButton"
                                        MinWidth="150"
                                        Margin="0,20,0,0"
                                        Click="TestBenchStartStopButton_Click"
                                        Content="Start Test Bench" />
                            </WrapPanel>

                            <UniformGrid Columns="4"
                                         Margin="0,18,0,0">
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="State" />
                                    <TextBlock x:Name="TestBenchStateText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Idle" />
                                </StackPanel>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Output Peak" />
                                    <TextBlock x:Name="TestBenchPeakText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="0.000" />
                                </StackPanel>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Limiter" />
                                    <TextBlock x:Name="TestBenchLimiterText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="0 limited" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Output" />
                                    <TextBlock x:Name="TestBenchOutputText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Null Output" />
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock x:Name="TestBenchWarningText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Physical shaker feel, safe gain, latency, and frequency tuning are not validated until real hardware testing." />
                        </StackPanel>
                    </Border>

                    <Border x:Name="MixerPanel"
                            Margin="0,0,0,24"
                            Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Mixer And Safety" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="These controls feed the Stage 10 mixer and safety chain. They are normalized software levels, not physical shaker calibration." />
                            <UniformGrid Columns="2"
                                         Margin="0,18,0,0">
                                <StackPanel Margin="0,0,24,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Master gain" />
                                    <Slider x:Name="MasterGainSlider"
                                            Maximum="1"
                                            Minimum="0"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="MasterGainValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <CheckBox x:Name="MixerMuteCheckBox"
                                              Margin="0,12,0,0"
                                              Checked="TuningControl_Changed"
                                              Content="Normal mute"
                                              Unchecked="TuningControl_Changed" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Safety output gain" />
                                    <Slider x:Name="SafetyOutputGainSlider"
                                            Maximum="0.5"
                                            Minimum="0"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="SafetyOutputGainValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Conservative output ceiling" />
                                    <Slider x:Name="SafetyOutputCeilingSlider"
                                            Maximum="0.75"
                                            Minimum="0.05"
                                            ValueChanged="TuningControl_Changed" />
                                    <TextBlock x:Name="SafetyOutputCeilingValueText"
                                               Foreground="{DynamicResource AppMutedTextBrush}" />
                                    <CheckBox x:Name="LimiterEnabledCheckBox"
                                              Margin="0,12,0,0"
                                              Checked="TuningControl_Changed"
                                              Content="Limiter enabled"
                                              Unchecked="TuningControl_Changed" />
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border x:Name="DevicesPanel"
                            Margin="0,0,0,24"
                            Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Safe Output Status" />
                            <TextBlock x:Name="CurrentOutputStatusText"
                                       Margin="0,12,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="NullOutputStatusText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="WasapiDebugStatusText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="AsioStatusText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock Margin="0,18,0,0"
                                       FontWeight="SemiBold"
                                       Text="Output Selection" />
                            <WrapPanel Margin="0,10,0,0">
                                <ComboBox x:Name="OutputModeComboBox"
                                          Width="150"
                                          Margin="0,0,8,8"
                                          DisplayMemberPath="Label"
                                          SelectionChanged="OutputModeComboBox_SelectionChanged" />
                                <Button Width="130"
                                        Margin="0,0,8,8"
                                        Click="RefreshAsioButton_Click"
                                        Content="Refresh ASIO" />
                            </WrapPanel>
                            <TextBlock Margin="0,10,0,0"
                                       FontWeight="SemiBold"
                                       Text="ASIO Readiness" />
                            <WrapPanel Margin="0,10,0,0">
                                <ComboBox x:Name="AsioDriverComboBox"
                                          Width="260"
                                          Margin="0,0,8,8"
                                          SelectionChanged="AsioDriverComboBox_SelectionChanged" />
                                <ComboBox x:Name="AsioOutputChannelComboBox"
                                          Width="120"
                                          Margin="0,0,8,8"
                                          SelectionChanged="AsioOutputChannelComboBox_SelectionChanged" />
                                <CheckBox x:Name="AsioArmCheckBox"
                                          Margin="0,4,8,8"
                                          Checked="AsioArmCheckBox_Changed"
                                          Unchecked="AsioArmCheckBox_Changed"
                                          Content="Arm ASIO" />
                            </WrapPanel>
                            <TextBlock x:Name="AsioReadinessStatusText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="HardwareChainStatusText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="RecordingsPanel"
                            Margin="0,0,0,24"
                            Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Recording And Replay" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Recording captures raw UDP payload bytes before parser validation. Replay feeds recorded packets through the same parser, VehicleState, effects, mixer, safety, and Null output path." />
                            <WrapPanel Margin="0,16,0,0">
                                <Button x:Name="RecordingsStartStopButton"
                                        Width="150"
                                        Margin="0,0,8,0"
                                        HorizontalAlignment="Left"
                                        Click="StartRecordingButton_Click"
                                        Content="Start Recording" />
                                <Button x:Name="ReplayStartStopButton"
                                        Width="140"
                                        HorizontalAlignment="Left"
                                        Click="StartReplayButton_Click"
                                        Content="Replay Latest" />
                            </WrapPanel>
                            <TextBlock x:Name="RecordingsDetailText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="ReplayDetailText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="ProfilesPanel"
                            Margin="0,0,0,24"
                            Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Profiles" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Profiles are versioned JSON tuning snapshots stored under local app data. Emergency mute is runtime-only and is not saved." />
                            <TextBlock Margin="0,16,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Profile name" />
                            <TextBox x:Name="ProfileNameTextBox"
                                     MaxWidth="360"
                                     HorizontalAlignment="Left" />
                            <WrapPanel Margin="0,14,0,0">
                                <Button Width="120"
                                        Margin="0,0,8,0"
                                        Click="SaveProfileButton_Click"
                                        Content="Save Profile" />
                                <Button Width="120"
                                        Margin="0,0,8,0"
                                        Click="LoadProfileButton_Click"
                                        Content="Load Profile" />
                                <Button Width="150"
                                        Click="ResetProfileButton_Click"
                                        Content="Reset Defaults" />
                            </WrapPanel>
                            <TextBlock x:Name="ProfileStatusText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="ProfilePathText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <TextBlock x:Name="ProfileValidationText"
                                       Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="SettingsPanel"
                            Margin="0,0,0,24"
                            Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Settings" />
                            <CheckBox x:Name="SettingsLightThemeCheckBox"
                                      Margin="0,12,0,0"
                                      Checked="ThemeSettingCheckBox_Changed"
                                      Content="Use light theme"
                                      Unchecked="ThemeSettingCheckBox_Changed" />
                            <Button Width="190"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="ResetProfileButton_Click"
                                    Content="Reset Conservative Defaults" />
                            <TextBlock x:Name="SettingsStatusText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                        </StackPanel>
                    </Border>

                    <Border x:Name="DiagnosticsPanel"
                            Margin="0,0,0,24"
                            Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Runtime Diagnostics" />
                            <Button Width="150"
                                    Margin="0,14,0,0"
                                    HorizontalAlignment="Left"
                                    Click="RefreshDiagnosticsButton_Click"
                                    Content="Refresh Diagnostics" />
                            <TextBlock x:Name="DiagnosticsSummaryText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}" />
                            <ItemsControl x:Name="DiagnosticsItemsControl"
                                          Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="0,0,0,8"
                                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                                   Text="{Binding}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Border Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock x:Name="PageStatusText"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <ItemsControl x:Name="PageItemsControl"
                                          Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="6"
                                                     Height="6"
                                                     VerticalAlignment="Top"
                                                     Margin="0,7,0,0"
                                                     Fill="{DynamicResource AppAccentBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       Text="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterStatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="Ready - Stage 15 mock pipeline" />
                <CheckBox Grid.Column="1"
                          Content="Minimize to tray on close"
                          IsEnabled="False" />
            </Grid>
        </Border>
    </Grid>
</Window>
