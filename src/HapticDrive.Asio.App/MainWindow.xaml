<Window x:Class="HapticDrive.Asio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Haptic Drive ASIO"
        Height="780"
        Width="1240"
        MinHeight="640"
        MinWidth="980"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="78" />
            <RowDefinition Height="*" />
            <RowDefinition Height="36" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid Margin="24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock FontSize="24"
                               FontWeight="Bold"
                               Text="Haptic Drive ASIO" />
                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                               Text="Stage 11 test bench" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Border Margin="0,0,12,0"
                            Padding="12,7"
                            Background="{DynamicResource AppSurfaceAltBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <TextBlock x:Name="TelemetryStatusText"
                                   Foreground="{DynamicResource AppMutedTextBrush}"
                                   Text="UDP: starting" />
                    </Border>
                    <Button x:Name="StartStopButton"
                            Margin="0,0,8,0"
                            Click="StartStopButton_Click"
                            Content="Start Haptics" />
                    <Button x:Name="StartRecordingButton"
                            Margin="0,0,8,0"
                            Click="StartRecordingButton_Click"
                            Content="Start Recording" />
                    <Button x:Name="EmergencyMuteButton"
                            Margin="0,0,8,0"
                            Background="{DynamicResource AppDangerBrush}"
                            BorderBrush="{DynamicResource AppDangerBrush}"
                            Click="EmergencyMuteButton_Click"
                            Content="Emergency Mute" />
                    <Button x:Name="ThemeButton"
                            Click="ThemeButton_Click"
                            Content="Theme: Dark" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Background="{DynamicResource AppSurfaceBrush}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,1,0">
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Margin="20,18,20,10"
                               Foreground="{DynamicResource AppMutedTextBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Text="WORKSPACE" />
                    <ListBox x:Name="NavigationList"
                             Margin="12,0,12,16"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="{DynamicResource AppTextBrush}"
                             SelectionChanged="NavigationList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Padding="12,9"
                                           Text="{Binding NavigationLabel}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="0,2" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Background" Value="Transparent" />
                                <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="{DynamicResource AppSurfaceAltBrush}" />
                                        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>
                </DockPanel>
            </Border>

            <ScrollViewer Grid.Column="1"
                          Padding="28"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock x:Name="PageTitleText"
                               FontSize="30"
                               FontWeight="Bold" />
                    <TextBlock x:Name="PageSummaryText"
                               Margin="0,8,0,24"
                               FontSize="15"
                               Foreground="{DynamicResource AppMutedTextBrush}" />

                    <UniformGrid Columns="4"
                                 Margin="0,0,0,24">
                        <Border Margin="0,0,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Output Mode" />
                                <TextBlock x:Name="OutputModeValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Not configured" />
                                <TextBlock x:Name="OutputModeDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Stage 02 adds hardware-absent output devices." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Haptics" />
                                <TextBlock x:Name="HapticsStateText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Stopped" />
                                <TextBlock Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Stage 10 feeds safe silence through Null output." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,0,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="UDP Listener" />
                                <TextBlock x:Name="UdpListenerValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Starting" />
                                <TextBlock x:Name="UdpListenerDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Default port 20778." />
                            </StackPanel>
                        </Border>

                        <Border Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Packets" />
                                <TextBlock x:Name="PacketCountValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="0" />
                                <TextBlock x:Name="PacketRateDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="0.00 packets/s" />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Forwarding" />
                                <TextBlock x:Name="ForwardingValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Disabled" />
                                <TextBlock x:Name="ForwardingDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="No destinations configured." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="F1 25 Parser" />
                                <TextBlock x:Name="HeaderParserValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Waiting" />
                                <TextBlock x:Name="HeaderParserDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="No packets parsed yet." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,12,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="VehicleState" />
                                <TextBlock x:Name="VehicleStateValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Waiting" />
                                <TextBlock x:Name="VehicleStateDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="No vehicle samples mapped yet." />
                            </StackPanel>
                        </Border>

                        <Border Margin="0,12,0,0"
                                Padding="18"
                                Background="{DynamicResource AppSurfaceBrush}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <StackPanel>
                                <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Recording" />
                                <TextBlock x:Name="RecordingValueText"
                                           FontSize="20"
                                           FontWeight="SemiBold"
                                           Text="Idle" />
                                <TextBlock x:Name="RecordingDetailText"
                                           Margin="0,6,0,0"
                                           Foreground="{DynamicResource AppMutedTextBrush}"
                                           Text="Ready to capture raw UDP packets." />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border x:Name="TestBenchPanel"
                            Margin="0,0,0,24"
                            Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Synthetic Test Bench" />
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Render deterministic validation buffers through the Stage 10 mixer, safety chain, and Null output." />

                            <WrapPanel Margin="0,16,0,0"
                                       VerticalAlignment="Center">
                                <StackPanel Width="240"
                                            Margin="0,0,16,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Signal" />
                                    <ComboBox x:Name="TestBenchSignalComboBox"
                                              Margin="0,6,0,0"
                                              DisplayMemberPath="DisplayName"
                                              SelectionChanged="TestBenchSignalComboBox_SelectionChanged" />
                                </StackPanel>

                                <Button x:Name="TestBenchStartStopButton"
                                        MinWidth="150"
                                        Margin="0,20,0,0"
                                        Click="TestBenchStartStopButton_Click"
                                        Content="Start Test Bench" />
                            </WrapPanel>

                            <UniformGrid Columns="4"
                                         Margin="0,18,0,0">
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="State" />
                                    <TextBlock x:Name="TestBenchStateText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Idle" />
                                </StackPanel>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Output Peak" />
                                    <TextBlock x:Name="TestBenchPeakText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="0.000" />
                                </StackPanel>
                                <StackPanel Margin="0,0,18,0">
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Limiter" />
                                    <TextBlock x:Name="TestBenchLimiterText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="0 limited" />
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Foreground="{DynamicResource AppMutedTextBrush}"
                                               Text="Output" />
                                    <TextBlock x:Name="TestBenchOutputText"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Text="Null Output" />
                                </StackPanel>
                            </UniformGrid>

                            <TextBlock x:Name="TestBenchWarningText"
                                       Margin="0,14,0,0"
                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                       Text="Physical shaker feel, safe gain, latency, and frequency tuning are not validated until real hardware testing." />
                        </StackPanel>
                    </Border>

                    <Border Padding="22"
                            Background="{DynamicResource AppSurfaceBrush}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <StackPanel>
                            <TextBlock x:Name="PageStatusText"
                                       FontSize="18"
                                       FontWeight="SemiBold" />
                            <ItemsControl x:Name="PageItemsControl"
                                          Margin="0,14,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="18" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Ellipse Width="6"
                                                     Height="6"
                                                     VerticalAlignment="Top"
                                                     Margin="0,7,0,0"
                                                     Fill="{DynamicResource AppAccentBrush}" />
                                            <TextBlock Grid.Column="1"
                                                       Foreground="{DynamicResource AppMutedTextBrush}"
                                                       Text="{Binding}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Border Grid.Row="2"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid Margin="18,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="FooterStatusText"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource AppMutedTextBrush}"
                           Text="Ready - Stage 01 shell only" />
                <CheckBox Grid.Column="1"
                          Content="Minimize to tray on close"
                          IsEnabled="False" />
            </Grid>
        </Border>
    </Grid>
</Window>
